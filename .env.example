# Free-first mode (recommended): keep remote API disabled.
NEXT_PUBLIC_USE_REMOTE_API=false
NEXT_PUBLIC_APP_TIME_ZONE=America/Chicago

# Local parent PIN in browser storage mode:
# hash format = sha256("<PIN>:<NEXT_PUBLIC_PARENT_PIN_PEPPER>")
NEXT_PUBLIC_PARENT_PIN_PLAIN=1234
NEXT_PUBLIC_PARENT_PIN_HASH=
NEXT_PUBLIC_PARENT_PIN_PEPPER=herohabits-dev-pepper

# Optional Supabase remote mode (only needed when NEXT_PUBLIC_USE_REMOTE_API=true)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-side parent auth (used by API routes)
PARENT_PIN_PLAIN=1234
PARENT_PIN_HASH=
PARENT_PIN_PEPPER=herohabits-dev-pepper

# Session + internal cron auth
PARENT_SESSION_SECRET=replace-with-random-secret
INTERNAL_CRON_SECRET=replace-with-random-secret
APP_TIME_ZONE=America/Chicago

# Optional AI mission generator
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
